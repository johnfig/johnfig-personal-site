---
import Layout from '../layouts/Layout.astro';
import HomeTicker from '../components/HomeTicker.tsx';

const stats = [
  { v: '$101M', l: 'ARR built at SISU',  c: 'var(--accent)'   },
  { v: '$100M', l: 'Exit, $1B txn',       c: 'var(--accent-2)' },
  { v: '1M+',   l: 'Plaito downloads',    c: 'var(--accent-3)' },
  { v: '180',   l: 'Countries reached',   c: 'var(--accent-4)' },
];

const ventures = [
  { n: 'SISU Extracts', s: '$101M ARR · acquired',          y: '2017–2022', c: 'var(--accent)',   d: 'Co-founder & CEO. Zero to nine figures. $100M exit in a $1B transaction with Jay-Z as Chief Visionary Officer.', href: '/ventures/sisu-extracts' },
  { n: 'Plaito',        s: '1M+ downloads · 180 countries', y: '2022–2024', c: 'var(--accent-2)', d: 'AI tutor for the world. Tried & failed — but the mission of equal-access education still drives me.',          href: '/ventures/plaito' },
  { n: 'SISU Ventures', s: 'Real estate · cash-flowing markets', y: '2024–now', c: 'var(--accent-3)', d: 'Value-add real estate portfolio. Compounding. Patient capital.',                                              href: '/ventures/sisu-ventures' },
];

const timeline = [
  { y: 'EARLY', t: 'Northern California',                   d: "Small rural town. Family ran video stores for 30 years. Top-15 in the country in distance running.", c: 'var(--accent-4)', side: 'L' },
  { y: '2010s', t: 'Driving limos · sleeping in a Civic',   d: "Self-taught engineering at night. Goodshop · Pivotal Labs · Teespring senior eng manager.",          c: 'var(--accent-2)', side: 'R' },
  { y: '2017',  t: 'Founded SISU Extracts',                 d: "$0 to $101M ARR with farmers in the hills my family has known for decades.",                         c: 'var(--accent)',   side: 'L' },
  { y: '2022',  t: '$100M exit, $1B transaction',           d: "Acquired with Jay-Z as Chief Visionary Officer. SISU is now employee-owned.",                        c: 'var(--accent)',   side: 'R' },
  { y: '2022',  t: 'Plaito · 1M downloads',                 d: "AI tutor in 180 countries, 40 languages. The business failed; the mission didn't.",                  c: 'var(--accent-2)', side: 'L' },
  { y: 'NOW',   t: 'SISU Ventures + Family',                d: "Real estate. Writing. SF. Wife and son — the reason any of it matters.",                             c: 'var(--accent-3)', side: 'R' },
];
---
<Layout title="John Figueiredo — Founder, Builder, Investor" active="Home" description="John Figueiredo grew SISU Extracts from $0 to $101M ARR and a $100M exit. Shipped Plaito to 1M students in 180 countries. Now building SISU Ventures.">
  <div style="position:relative;overflow:hidden;">
    <!-- Animated gradient orbs -->
    <div aria-hidden="true" style="position:absolute;inset:0;pointer-events:none;overflow:hidden;z-index:0;">
      <div style="position:absolute;top:-10%;left:-10%;width:600px;height:600px;border-radius:50%;background:radial-gradient(circle, rgba(158,255,90,0.2), transparent 70%);filter:blur(80px);animation:float1 12s ease-in-out infinite;"></div>
      <div style="position:absolute;top:30%;right:-15%;width:700px;height:700px;border-radius:50%;background:radial-gradient(circle, rgba(90,214,255,0.15), transparent 70%);filter:blur(90px);animation:float2 14s ease-in-out infinite;"></div>
      <div style="position:absolute;bottom:-10%;left:20%;width:500px;height:500px;border-radius:50%;background:radial-gradient(circle, rgba(196,123,255,0.13), transparent 70%);filter:blur(70px);animation:float3 16s ease-in-out infinite;"></div>
    </div>

    <div style="position:relative;z-index:1;">
      <!-- HERO -->
      <section class="section hero-grid" style="padding-top:48px;padding-bottom:36px;display:grid;grid-template-columns:1.3fr 1fr;gap:48px;align-items:center;">
        <div>
          <span class="label">BUILDING THE FUTURE · EST. 2018</span>
          <h1 class="display hero-title" style="line-height:0.9;letter-spacing:-0.045em;margin:18px 0 0;font-weight:700;background:linear-gradient(135deg, var(--text) 0%, var(--text) 50%, var(--accent) 100%);-webkit-background-clip:text;background-clip:text;color:transparent;">
            Time to<br/>Build<span style="color:var(--accent);">.</span>
          </h1>

          <HomeTicker client:load />

          <p class="sans" style="margin-top:20px;font-size:clamp(15px,1.4vw,17px);line-height:1.55;color:var(--text-soft);max-width:520px;font-weight:400;">
            I grew SISU from zero to $101M ARR and a $100M exit. Shipped an AI tutor to a million students in 180 countries. Now building SISU Ventures and writing about the slow patient work of compounding.
          </p>

          <div style="margin-top:24px;display:flex;gap:12px;flex-wrap:wrap;">
            <a href="/bio" class="btn btn-primary" style="padding:14px 24px;">Read the full story →</a>
            <a href="/contact" class="btn btn-ghost" style="padding:14px 24px;">Get in touch</a>
          </div>
        </div>

        <!-- Portrait — floating, glowing -->
        <div class="portrait-wrap" style="position:relative;max-width:380px;width:100%;margin:0 auto;">
          <div aria-hidden="true" style="position:absolute;inset:-20px;border-radius:24px;background:conic-gradient(from 0deg, var(--accent), var(--accent-2), var(--accent-4), var(--accent-3), var(--accent));filter:blur(40px);opacity:0.4;animation:spin 20s linear infinite;"></div>
          <div role="img" aria-label="Portrait of John Figueiredo" style="position:relative;width:100%;aspect-ratio:1/1;background-image:url('/assets/portrait.jpeg');background-size:cover;background-position:center;border-radius:16px;border:1px solid var(--border);box-shadow:0 30px 80px rgba(0,0,0,0.6);"></div>
          <div style="position:absolute;bottom:16px;left:16px;right:16px;padding:12px 16px;border-radius:10px;background:rgba(10,10,12,0.7);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);border:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;">
            <span class="mono" style="font-size:11px;color:var(--text-soft);letter-spacing:0.15em;">STATUS</span>
            <span class="mono" style="font-size:11px;color:var(--accent);letter-spacing:0.15em;display:flex;align-items:center;gap:8px;">
              <span aria-hidden="true" style="width:8px;height:8px;border-radius:50%;background:var(--accent);box-shadow:0 0 8px var(--accent);"></span>
              BUILDING
            </span>
          </div>
        </div>
      </section>

      <!-- STATS BAR -->
      <section class="section" style="padding-bottom:0;">
        <div class="stats-bar stats-card" style="margin:0 auto;padding:32px 40px;background:var(--surface);border:1px solid var(--border);border-radius:16px;display:grid;grid-template-columns:repeat(4,1fr);gap:32px;">
          {stats.map((s, i) => (
            <div style={`border-left:${i > 0 ? '1px solid var(--border)' : 'none'};padding-left:${i > 0 ? '32px' : '0'};`}>
              <div class="display" style={`font-size:clamp(36px,5vw,56px);font-weight:700;line-height:1;color:${s.c};letter-spacing:-0.03em;`}>{s.v}</div>
              <div class="sans" style="margin-top:10px;font-size:14px;color:var(--text-soft);">{s.l}</div>
            </div>
          ))}
        </div>
      </section>

      <!-- VENTURES -->
      <section class="section" style="padding-top:120px;padding-bottom:60px;">
        <div style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:48px;flex-wrap:wrap;gap:16px;">
          <div>
            <span class="label cyan">VENTURES — WHAT I'VE BUILT</span>
            <h2 class="display section-title" style="line-height:0.95;letter-spacing:-0.035em;margin:16px 0 0;font-weight:700;">
              The work<span style="color:var(--accent-2);">.</span>
            </h2>
          </div>
        </div>

        <div class="three-col" style="display:grid;grid-template-columns:repeat(3,1fr);gap:24px;">
          {ventures.map((v, i) => (
            <a href={v.href} style="position:relative;overflow:hidden;padding:32px;border-radius:20px;background:var(--surface);border:1px solid var(--border);text-decoration:none;color:var(--text);display:flex;flex-direction:column;justify-content:space-between;min-height:360px;transition:transform 0.3s;">
              <div aria-hidden="true" style={`position:absolute;top:-50px;right:-50px;width:200px;height:200px;border-radius:50%;background:radial-gradient(circle, ${v.c}, transparent 70%);opacity:0.25;filter:blur(40px);`}></div>
              <div style="position:relative;">
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:24px;">
                  <span style={`padding:4px 10px;border-radius:999px;font-size:10px;font-family:'JetBrains Mono',monospace;letter-spacing:0.15em;color:${v.c};border:1px solid ${v.c};background:rgba(255,255,255,0.04);`}>{v.y}</span>
                  <span class="mono" style="font-size:11px;color:var(--text-dim);letter-spacing:0.1em;">0{i + 1}</span>
                </div>
                <h3 class="display card-title" style="line-height:1.05;letter-spacing:-0.02em;margin:0;font-weight:700;">{v.n}</h3>
                <div class="mono" style={`margin-top:8px;font-size:12px;color:${v.c};letter-spacing:0.05em;`}>{v.s}</div>
                <p class="sans" style="margin-top:18px;font-size:15px;line-height:1.55;color:var(--text-soft);font-weight:400;">{v.d}</p>
              </div>
              <div style="position:relative;display:flex;justify-content:space-between;align-items:center;margin-top:24px;padding-top:20px;border-top:1px solid var(--border);">
                <span class="mono" style="font-size:11px;color:var(--text-dim);letter-spacing:0.18em;">EXPLORE</span>
                <span style={`font-size:20px;color:${v.c};`}>→</span>
              </div>
            </a>
          ))}
        </div>
      </section>

      <!-- TIMELINE -->
      <section class="section" style="padding-top:60px;padding-bottom:60px;">
        <span class="label ember">THE ARC — A LIFE IN MOTION</span>
        <h2 class="display section-title" style="line-height:0.95;letter-spacing:-0.035em;margin:16px 0 56px;font-weight:700;">
          From a small town<br/>to nine figures<span style="color:var(--accent-3);">.</span>
        </h2>

        <div class="timeline-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:0;position:relative;">
          <div class="timeline-line" aria-hidden="true" style="position:absolute;left:50%;top:0;bottom:0;width:2px;background:linear-gradient(to bottom, rgba(158,255,90,0.4), rgba(90,214,255,0.4), rgba(255,107,61,0.4));"></div>
          {timeline.map((it) => (
            it.side === 'L' ? (
              <>
                <div style="padding:16px 48px 48px 0;text-align:right;position:relative;">
                  <div class="mono" style={`font-size:11px;color:${it.c};letter-spacing:0.2em;`}>{it.y}</div>
                  <h3 class="display" style="font-size:clamp(24px,3vw,32px);line-height:1.1;font-weight:700;letter-spacing:-0.02em;margin:8px 0;">{it.t}</h3>
                  <p class="sans" style="font-size:15px;line-height:1.5;color:var(--text-soft);margin:0;margin-left:auto;max-width:380px;">{it.d}</p>
                </div>
                <div style="position:relative;">
                  <span aria-hidden="true" style={`position:absolute;left:-7px;top:24px;width:16px;height:16px;border-radius:50%;background:${it.c};box-shadow:0 0 16px ${it.c};`}></span>
                </div>
              </>
            ) : (
              <>
                <div style="position:relative;">
                  <span aria-hidden="true" style={`position:absolute;right:-7px;top:24px;width:16px;height:16px;border-radius:50%;background:${it.c};box-shadow:0 0 16px ${it.c};`}></span>
                </div>
                <div style="padding:16px 0 48px 48px;">
                  <div class="mono" style={`font-size:11px;color:${it.c};letter-spacing:0.2em;`}>{it.y}</div>
                  <h3 class="display" style="font-size:clamp(24px,3vw,32px);line-height:1.1;font-weight:700;letter-spacing:-0.02em;margin:8px 0;">{it.t}</h3>
                  <p class="sans" style="font-size:15px;line-height:1.5;color:var(--text-soft);margin:0;max-width:380px;">{it.d}</p>
                </div>
              </>
            )
          ))}
        </div>
      </section>

      <!-- CTA -->
      <section class="section" style="padding-top:80px;padding-bottom:100px;">
        <div style="padding:clamp(32px,6vw,60px) clamp(20px,5vw,48px);background:linear-gradient(135deg, rgba(158,255,90,0.1), rgba(90,214,255,0.1), rgba(196,123,255,0.1));border:1px solid var(--border);border-radius:24px;text-align:center;position:relative;overflow:hidden;">
          <span class="label">LET'S BUILD</span>
          <h2 class="display section-title" style="line-height:0.95;letter-spacing:-0.035em;margin:16px 0 24px;font-weight:700;">
            The next chapter is<br/>
            <span style="background:linear-gradient(90deg, var(--accent), var(--accent-2));-webkit-background-clip:text;background-clip:text;color:transparent;">still unwritten.</span>
          </h2>
          <p class="sans" style="font-size:clamp(15px,1.6vw,18px);color:var(--text-soft);max-width:560px;margin:0 auto;">
            Building, investing, or just want to talk education and compounding? My inbox is open.
          </p>
          <a href="/contact" class="btn btn-light" style="margin-top:32px;padding:18px 36px;font-size:15px;">Get in touch →</a>
        </div>
      </section>
    </div>
  </div>
</Layout>
