---
import Layout from '../layouts/Layout.astro';

const milestones: [string, string, string][] = [
  ['EARLY', 'Northern California · video stores',           'var(--accent-4)'],
  ['HS',    'Top-15 in the country, distance running',      'var(--accent-3)'],
  ['2010',  'Oregon · D1 running, BS Business',             'var(--text)'],
  ['2010',  'SF · limo driver, Airbnb host, 16-unit ops',   'var(--text-soft)'],
  ['2012',  'Gopago · self-taught back-end engineering',    'var(--accent-2)'],
  ['2014',  'Byliner · Goodshop',                            'var(--accent-2)'],
  ['2016',  'Teespring · Sr Eng Manager · $60M built',      'var(--accent-2)'],
  ['2017',  'SISU Extracts · founded',                      'var(--accent)'],
  ['2022',  '$100M exit · $1B transaction',                 'var(--accent)'],
  ['2022',  'Plaito · 1M+ downloads',                       'var(--accent-2)'],
  ['2024',  'SISU Ventures · CEO',                          'var(--accent-3)'],
  ['NOW',   'Sierra foothills · real estate · investing',   'var(--accent)'],
];

// Curated positive press, podcast appearances, and authoritative profiles.
// These power both the visible "Press & Mentions" section and the Person
// schema sameAs[] — the most important Knowledge Graph entity signal.
type Press = { outlet: string; date: string; title: string; href: string; kind: 'Article' | 'Podcast' | 'Profile' };
const press: Press[] = [
  { outlet: 'MG Magazine',              date: '2019',    kind: 'Article', title: 'Sisu Extracts: Turning Trim into Gold',                                          href: 'https://mgmagazine.com/business/retail-merchandise/sisu-extracts-turning-trim-into-gold/' },
  { outlet: 'MJBizDaily',               date: '2020',    kind: 'Article', title: 'How to Keep Extraction Costs Low (with John Figueiredo, CEO)',                  href: 'https://mjbizdaily.com/how-to-keep-extraction-costs-low/' },
  { outlet: 'Cannabis Business Times',  date: '2020',    kind: 'Article', title: 'Left Coast Ventures Announces Acquisition of Sisu Extracts',                    href: 'https://www.cannabisbusinesstimes.com/business-issues-benchmarks/finance/news/15691093/left-coast-ventures-announces-acquisition-of-sisu-extracts' },
  { outlet: 'Extraction Magazine',      date: '2019',    kind: 'Article', title: "California's Leading Extractor Fills Two Million Cartridges Per Month",         href: 'https://extractionmagazine.com/2019/07/03/leading-california-extractor-fills-two-million-cartridges-per-month-with-next-generation-distillate/' },
  { outlet: 'BusinessWire',             date: '2020',    kind: 'Article', title: 'Left Coast Ventures Announces Acquisition of Sisu Extracts',                    href: 'https://www.businesswire.com/news/home/20200310005364/en/Left-Coast-Ventures-Announces-Acquisition-of-Sisu-Extracts' },
  { outlet: 'Green Market Report',      date: '2021',    kind: 'Article', title: 'Subversive SPAC Forms The Parent Company With Jay-Z & Roc Nation',              href: 'https://www.greenmarketreport.com/subversive-spac-forms-the-parent-company-with-jaz-z-roc-nation/' },
  { outlet: 'Benzinga',                 date: '2022',    kind: 'Article', title: 'The Parent Company Divests Wholesale Cannabis Extraction Division',             href: 'https://www.benzinga.com/markets/cannabis/22/11/29547180/the-parent-company-divests-wholesale-cannabis-extraction-division' },
  { outlet: 'RWS Magazine',             date: '2023',    kind: 'Article', title: "Plaito's AI Education Platform to Reach 1M Downloads",                          href: 'https://rwsmagazine.com/plaitos-ai-education-platform-to-reach-1m-downloads/' },
  { outlet: 'BUILDERS w/ Alex Snider',  date: '2022',    kind: 'Podcast', title: 'From Limo Driver to 9-Figure Founder',                                          href: 'https://www.youtube.com/watch?v=wdzl2ribBxE' },
  { outlet: 'Hemp Barons Podcast',      date: '2019',    kind: 'Podcast', title: 'Sisu Extracts — John Figueiredo & Joe Wynne',                                   href: 'https://podcasts.apple.com/us/podcast/sisu-extracts-john-figueiredo-joe-wynne/id1455758113?i=1000441098909' },
  { outlet: 'Crunchbase',               date: 'Profile', kind: 'Profile', title: 'John Figueiredo — President of SISU @ The Parent Company',                      href: 'https://www.crunchbase.com/person/john-figueiredo' },
  { outlet: 'Pitchbook',                date: 'Profile', kind: 'Profile', title: 'Sisu Extracts — Valuation, Investors, Acquisition',                             href: 'https://pitchbook.com/profiles/company/433116-28' },
  { outlet: 'LinkedIn',                 date: 'Profile', kind: 'Profile', title: 'John Figueiredo — Determined to Build a Brighter Future',                       href: 'https://www.linkedin.com/in/john-fig/' },
];

// Bio-specific structured data: ProfilePage + BreadcrumbList.
const profilePageSchema = {
  '@context': 'https://schema.org',
  '@type': 'ProfilePage',
  name: 'Bio — John Figueiredo',
  description: "From driving limos and sleeping in one to a $100M exit — the long-form story of John Figueiredo's career.",
  url: 'https://www.johnfigueiredo.com/bio',
  mainEntity: { '@type': 'Person', name: 'John Figueiredo', url: 'https://www.johnfigueiredo.com/' },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.johnfigueiredo.com/' },
    { '@type': 'ListItem', position: 2, name: 'Bio',  item: 'https://www.johnfigueiredo.com/bio'  },
  ],
};
---
<Layout
  title="Bio — John Figueiredo: From Limo Driver to $100M Founder"
  active="Bio"
  description="The long-form story of John Figueiredo: from driving limos in San Francisco to founding SISU Extracts ($101M ARR, $100M exit with Jay-Z), Plaito (1M+ downloads in 180 countries), and SISU Ventures."
  ogType="profile"
  jsonLd={[profilePageSchema, breadcrumbSchema]}
>
  <div style="position:relative;overflow:hidden;">
    <div aria-hidden="true" style="position:absolute;top:-10%;right:-10%;width:600px;height:600px;border-radius:50%;background:radial-gradient(circle, rgba(90,214,255,0.15), transparent 70%);filter:blur(80px);z-index:0;"></div>

    <div style="position:relative;z-index:1;">
      <section class="section" style="padding-top:100px;padding-bottom:40px;">
        <span class="label">BIO — THE LONG VERSION</span>
        <h1 class="display hero-title-md" style="line-height:0.92;letter-spacing:-0.04em;margin:20px 0 0;font-weight:700;max-width:1200px;font-size:clamp(34px, 9.5vw, 132px);">
          From driving a limo<br/>
          to a <span style="background:linear-gradient(90deg, var(--accent), var(--accent-2));-webkit-background-clip:text;background-clip:text;color:transparent;">nine-figure exit</span><span style="color:var(--accent-3);">.</span>
        </h1>
      </section>

      <section class="section two-col" style="padding-top:40px;padding-bottom:100px;display:grid;grid-template-columns:1.4fr 1fr;gap:64px;align-items:start;">
        <article class="sans" style="font-size:clamp(16px,1.7vw,19px);line-height:1.7;color:var(--text-soft);">
          <p style="margin:0;">
            <span class="display" style="float:left;font-size:96px;line-height:0.85;color:var(--accent);margin-right:14px;margin-top:6px;font-weight:700;">I</span>
            grew up in a small town in Northern California. My family ran a chain of video stores for thirty years — renting movies to farmers up in the hills who didn't have reliable internet. The same farmers I'd later partner with to build a cannabis distillate company. I was a top-fifteen distance runner in the country in high school, ran D1 at Oregon, and lost it to nerve damage in my foot. The piece of me that felt special was gone — and I spent the next decade trying to figure out what would replace it.
          </p>
          <p>
            I moved to San Francisco in 2010 because that's where the world's best operators were, and I knew you don't get world-class without competing against the best. To survive on $15/hour I drove a limo at night and slept in it; rented out my apartment on Airbnb to cover rent; and managed a 16-unit building on the side. Side-hustle economics taught me more about leverage than any book.
          </p>
          <p>
            I caught a break in customer service at <strong style="color:var(--text);">Gopago</strong>, a venture-backed startup, and taught myself back-end engineering at night. From there I went to <strong style="color:var(--text);">Byliner</strong>, then <strong style="color:var(--text);">Goodshop</strong>, then <strong style="color:var(--text);">Teespring</strong> as a senior engineering manager — leading a global team of eleven, building a $60M revenue stream in a year when the company had 60 days to survive, and shipping a weekend project that drove $1M/month in profit. Teespring offered me VP of Engineering. I turned it down to start my own company. Engineering taught me how to ship; managing taught me how to operate.
          </p>
          <blockquote style="margin:48px 0;padding:28px 32px;border-radius:16px;background:linear-gradient(135deg, rgba(158,255,90,0.1), rgba(90,214,255,0.08));border:1px solid var(--border);">
            <p class="display" style="font-size:clamp(24px,3.5vw,38px);line-height:1.2;color:var(--text);font-style:italic;margin:0;font-weight:600;letter-spacing:-0.01em;">
              "Time is the most valuable asset we have. The whole point is to earn enough of it back to spend it on things that actually matter."
            </p>
          </blockquote>
          <p>
            In 2017 I co-founded <a href="/ventures/sisu-extracts" style="color:var(--accent);font-weight:600;text-decoration:none;border-bottom:1px solid rgba(158,255,90,0.3);">SISU Extracts</a> with Joe Wynne and Shannon Byers. The pitch was simple: build the most reliable distillate in California, and pay farmers a 70/30 split in their favor. Five years later we had grown from inception to <strong style="color:var(--text);font-weight:600;">$101M in annual revenue</strong> and were acquired in a $1B transaction with Jay-Z as Chief Visionary Officer. SISU is now employee-owned.
          </p>
          <p>
            After SISU I went all-in on something I deeply care about — education. I founded <a href="/ventures/plaito" style="color:var(--accent-2);font-weight:600;text-decoration:none;border-bottom:1px solid rgba(90,214,255,0.3);">Plaito</a>, an AI tutor designed to dissolve the financial barrier between a student and a great teacher. We hit a million downloads, 130,000 weekly active users across 180 countries, in 40 languages. Ultimately the business didn't work — but the mission still does, and I'll keep returning to it.
          </p>
          <p>
            Today I live in the <strong style="color:var(--text);font-weight:600;">Sierra foothills</strong> with my wife and two sons, running a deliberately lifestyle-shaped business: managing a real estate portfolio through <a href="/ventures/sisu-ventures" style="color:var(--accent-3);font-weight:600;text-decoration:none;border-bottom:1px solid rgba(255,107,61,0.3);">SISU Ventures</a>, and incubating and investing in companies I want to spend time around. I write about frameworks, habits, and the slow patient work of compounding. The whole point of building was always to earn back the time to do this — and the family it's for is the reason any of it matters.
          </p>
          <p>
            Before all of this I was a runner — top fifteen in the country in high school for distance — and I still chase miles most mornings. The discipline that builds a company is the same discipline that builds a body of work. Show up. Suffer well. Compound.
          </p>
        </article>

        <aside style="display:flex;flex-direction:column;gap:32px;position:sticky;top:90px;">
          <div style="position:relative;">
            <div aria-hidden="true" style="position:absolute;inset:-10px;background:linear-gradient(135deg, var(--accent-3), var(--accent-4));border-radius:16px;opacity:0.4;filter:blur(20px);"></div>
            <img
              src="/assets/family.png"
              alt="John Figueiredo with his wife and son in the Sierra foothills"
              width="906"
              height="1363"
              loading="lazy"
              decoding="async"
              style="position:relative;width:100%;height:auto;aspect-ratio:3/4;object-fit:cover;display:block;border-radius:12px;border:1px solid var(--border);"
            />
          </div>
          <div style="font-size:13px;color:var(--text-dim);font-style:italic;text-align:center;">
            With my wife and two sons — the reason for everything.
          </div>

          <div style="padding:24px;border-radius:16px;background:var(--surface);border:1px solid var(--border);">
            <span class="label cyan">SELECTED TIMELINE</span>
            <div style="margin-top:16px;">
              {milestones.map((m, i) => (
                <div style={`display:grid;grid-template-columns:70px 1fr;padding:12px 0;border-bottom:${i < milestones.length - 1 ? '1px solid var(--border)' : 'none'};align-items:baseline;gap:12px;`}>
                  <span class="mono" style={`font-size:11px;color:${m[2]};letter-spacing:0.15em;`}>{m[0]}</span>
                  <span class="sans" style="font-size:14px;color:var(--text);line-height:1.4;">{m[1]}</span>
                </div>
              ))}
            </div>
          </div>
        </aside>
      </section>

      <!-- PRESS & MENTIONS -->
      <section class="section" style="padding-top:40px;padding-bottom:100px;position:relative;">
        <span class="label cyan">PRESS &amp; MENTIONS</span>
        <h2 class="display section-title" style="line-height:0.95;letter-spacing:-0.035em;margin:16px 0 12px;font-weight:700;font-size:clamp(36px,6vw,64px);">
          In the press<span style="color:var(--accent-2);">.</span>
        </h2>
        <p class="sans" style="font-size:clamp(15px,1.4vw,17px);line-height:1.55;color:var(--text-soft);max-width:640px;margin:0 0 36px;">
          A selection of articles, podcast appearances, and authoritative profiles covering SISU Extracts, Plaito, and the work along the way.
        </p>

        <ul class="press-grid" style="list-style:none;padding:0;margin:0;display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:14px;">
          {press.map((p) => (
            <li>
              <a
                href={p.href}
                target="_blank"
                rel="noopener external"
                class="press-card"
                style="display:flex;flex-direction:column;justify-content:space-between;height:100%;padding:20px 22px;border-radius:14px;background:var(--surface);border:1px solid var(--border);text-decoration:none;color:var(--text);transition:transform 0.2s ease, border-color 0.2s ease;"
              >
                <div style="display:flex;justify-content:space-between;align-items:center;gap:10px;">
                  <span class="mono" style="font-size:10px;letter-spacing:0.22em;color:var(--accent-2);text-transform:uppercase;">{p.outlet}</span>
                  <span class="mono" style="font-size:10px;letter-spacing:0.18em;color:var(--text-dim);">{p.kind} · {p.date}</span>
                </div>
                <div class="display" style="margin-top:14px;font-size:18px;line-height:1.3;font-weight:600;letter-spacing:-0.01em;">{p.title}</div>
                <div class="mono" style="margin-top:18px;font-size:11px;letter-spacing:0.2em;color:var(--text-dim);">READ ↗</div>
              </a>
            </li>
          ))}
        </ul>

        <div style="margin-top:32px;font-size:13px;color:var(--text-dim);font-style:italic;">
          Working on a piece about John Figueiredo, SISU Extracts, Plaito, or SISU Ventures? <a href="/contact" style="color:var(--text-soft);text-decoration:underline;">Get in touch.</a>
        </div>
      </section>
    </div>
  </div>

  <style>
    .press-card:hover { transform: translateY(-2px); border-color: var(--text-dim); }
  </style>
</Layout>
