---
import Layout from '../../layouts/Layout.astro';

const accent = 'var(--accent-3)';
const stats = [
  { v: 'Cash-flow first', l: 'Underwriting principle' },
  { v: 'Value-add',       l: 'Operating thesis' },
  { v: 'Patient',         l: 'Capital horizon' },
  { v: 'Foothills · 2024', l: 'HQ · founded' },
];
const pillars = [
  { n: '01', t: 'Cash-flowing markets', d: 'We start where the math already works. Not turnaround stories, not speculation — markets where rents cover debt service on day one.' },
  { n: '02', t: 'Value-add operating',  d: "We're operators first. Capex, repositioning, and management upgrades that move NOI in the first 24 months." },
  { n: '03', t: 'Patient compounding',  d: 'No fund clock. We hold what works. The real return is in year seven, not year one.' },
];
---
<Layout title="SISU Ventures — John Figueiredo" active="Home" description="SISU Ventures: a value-add real estate platform investing in high cash-flowing markets. Patient capital, operator-led.">
  <div style="position:relative;overflow:hidden;">
    <div aria-hidden="true" style="position:absolute;top:-10%;right:-10%;width:700px;height:700px;border-radius:50%;background:radial-gradient(circle, rgba(255,107,61,0.15), transparent 70%);filter:blur(90px);z-index:0;"></div>
    <div aria-hidden="true" style="position:absolute;bottom:-15%;left:-10%;width:600px;height:600px;border-radius:50%;background:radial-gradient(circle, rgba(255,107,61,0.12), transparent 70%);filter:blur(80px);z-index:0;"></div>

    <div style="position:relative;z-index:1;">
      <section class="section" style="padding-top:100px;padding-bottom:40px;">
        <span class="label ember">VENTURE 03 · 2024–NOW · CEO</span>
        <h1 class="display hero-title-md" style="line-height:0.9;letter-spacing:-0.045em;margin:20px 0 0;font-weight:700;background:linear-gradient(135deg, var(--text) 0%, var(--text) 50%, var(--accent-3) 100%);-webkit-background-clip:text;background-clip:text;color:transparent;">
          SISU<br/>Ventures<span style={`color:${accent};`}>.</span>
        </h1>
        <p class="sans" style="font-size:clamp(17px,2vw,22px);color:var(--text-soft);margin-top:24px;max-width:720px;font-weight:300;line-height:1.5;">
          A value-add real estate platform investing in high cash-flowing markets. The same operating discipline that built SISU Extracts, applied to physical assets that compound on a longer clock.
        </p>

        <div style="margin-top:48px;padding:clamp(28px,5vw,48px);border-radius:24px;background:linear-gradient(135deg, rgba(255,107,61,0.15), rgba(158,255,90,0.08));border:1px solid rgba(255,107,61,0.33);position:relative;overflow:hidden;">
          <div aria-hidden="true" style="position:absolute;inset:0;background:radial-gradient(circle at 70% 30%, rgba(255,107,61,0.2), transparent 60%);filter:blur(40px);"></div>
          <div class="two-col" style="position:relative;display:grid;grid-template-columns:1.5fr 1fr;gap:48px;align-items:center;">
            <div>
              <span class="label ember">OPERATING THESIS</span>
              <div class="display" style="font-size:clamp(26px,3.6vw,44px);margin-top:16px;line-height:1.1;font-weight:700;letter-spacing:-0.02em;">
                Buy quality assets in markets where the fundamentals already work — then operate them better than the seller could.
              </div>
            </div>
            <a href="https://www.sisuventures.co" target="_blank" rel="noopener noreferrer" class="btn" style={`background:${accent};color:var(--bg);font-size:16px;padding:20px 28px;justify-content:center;box-shadow:0 8px 30px rgba(255,107,61,0.33);`}>sisuventures.co →</a>
          </div>
        </div>
      </section>

      <section class="section" style="padding-top:60px;padding-bottom:40px;">
        <div class="stats-bar stats-card" style="padding:32px 40px;background:var(--surface);border:1px solid var(--border);border-radius:16px;display:grid;grid-template-columns:repeat(4,1fr);gap:32px;">
          {stats.map((s, i) => (
            <div style={`border-left:${i > 0 ? '1px solid var(--border)' : 'none'};padding-left:${i > 0 ? '32px' : '0'};`}>
              <div class="display" style={`font-size:clamp(22px,3vw,36px);font-weight:700;line-height:1.1;color:${accent};letter-spacing:-0.02em;`}>{s.v}</div>
              <div class="sans" style="margin-top:10px;font-size:14px;color:var(--text-soft);">{s.l}</div>
            </div>
          ))}
        </div>
      </section>

      <section class="section" style="padding-top:40px;padding-bottom:80px;">
        <h2 class="display section-title" style="line-height:1;font-weight:700;letter-spacing:-0.03em;margin:0 0 40px;">
          How we invest<span style={`color:${accent};`}>.</span>
        </h2>
        <div class="three-col" style="display:grid;grid-template-columns:repeat(3,1fr);gap:24px;">
          {pillars.map((p) => (
            <div style="padding:32px;border-radius:20px;background:var(--surface);border:1px solid var(--border);position:relative;overflow:hidden;">
              <div aria-hidden="true" style={`position:absolute;top:-40px;right:-40px;width:160px;height:160px;border-radius:50%;background:radial-gradient(circle, ${accent}, transparent 70%);opacity:0.2;filter:blur(30px);`}></div>
              <div style="position:relative;">
                <div class="mono" style={`font-size:11px;color:${accent};letter-spacing:0.2em;`}>{p.n}</div>
                <h3 class="display" style="font-size:clamp(22px,2.6vw,28px);line-height:1.15;font-weight:700;letter-spacing:-0.02em;margin:14px 0 12px;">{p.t}</h3>
                <p class="sans" style="font-size:15px;line-height:1.55;color:var(--text-soft);margin:0;">{p.d}</p>
              </div>
            </div>
          ))}
        </div>
      </section>
    </div>
  </div>
</Layout>
