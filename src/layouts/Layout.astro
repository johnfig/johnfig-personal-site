---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  active?: 'Home' | 'Bio' | 'Feed' | 'Contact';
  description?: string;
  /** Page type for OpenGraph: "website" (default), "article", "profile" */
  ogType?: 'website' | 'article' | 'profile';
  /** Optional override for OG image (absolute URL or path under /assets) */
  ogImage?: string;
  /** Extra structured-data JSON-LD blocks (already JSON-stringified) */
  jsonLd?: object[];
  /** Keywords meta (lightly weighted by some engines but never harmful) */
  keywords?: string;
  /** When true, emit `noindex,follow` (e.g. for 404 / drafts). */
  noIndex?: boolean;
}

const {
  title = 'John Figueiredo — Founder, Builder, Investor ($100M Exit)',
  active = 'Home',
  description = 'John Figueiredo grew SISU Extracts from $0 to $101M ARR and a $100M exit ($1B transaction with Jay-Z). Shipped Plaito to 1M+ students in 180 countries. Now running SISU Ventures.',
  ogType = 'website',
  ogImage = '/assets/portrait.jpeg',
  jsonLd = [],
  keywords = 'John Figueiredo, SISU Extracts, Plaito, SISU Ventures, founder, entrepreneur, $100M exit, AI tutor, real estate investor, Sierra foothills, cannabis founder, Jay-Z, The Parent Company',
  noIndex = false,
} = Astro.props;

const robotsContent = noIndex
  ? 'noindex,follow'
  : 'index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1';

const SITE_ORIGIN = 'https://www.johnfigueiredo.com';
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const absoluteOgImage = ogImage.startsWith('http') ? ogImage : `${SITE_ORIGIN}${ogImage}`;

// Person schema — the most important block for Google Knowledge Graph entity recognition.
const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'John Figueiredo',
  alternateName: ['John Fig', 'Johnny Figueiredo'],
  url: `${SITE_ORIGIN}/`,
  image: `${SITE_ORIGIN}/assets/portrait.jpeg`,
  jobTitle: 'Founder & CEO, SISU Ventures',
  hasOccupation: [
    {
      '@type': 'Occupation',
      name: 'Founder & CEO',
      occupationLocation: { '@type': 'Place', name: 'California, USA' },
    },
    { '@type': 'Occupation', name: 'Real estate investor' },
    { '@type': 'Occupation', name: 'Software engineer' },
  ],
  nationality: { '@type': 'Country', name: 'United States' },
  gender: 'Male',
  description:
    'Founder of SISU Extracts ($101M ARR, $100M exit in a $1B transaction with Jay-Z as Chief Visionary Officer), Plaito (AI tutor with 1M+ downloads in 180 countries), and SISU Ventures (real estate portfolio in cash-flowing markets).',
  knowsAbout: [
    'Entrepreneurship',
    'AI-powered education',
    'Real estate investing',
    'Cannabis industry',
    'Software engineering',
    'Compounding capital',
  ],
  worksFor: { '@type': 'Organization', name: 'SISU Ventures', url: `${SITE_ORIGIN}/ventures/sisu-ventures` },
  alumniOf: [
    { '@type': 'CollegeOrUniversity', name: 'University of Oregon' },
    { '@type': 'Organization', name: 'Goodshop' },
    { '@type': 'Organization', name: 'Teespring' },
  ],
  founder: [
    { '@type': 'Organization', name: 'SISU Extracts',  url: `${SITE_ORIGIN}/ventures/sisu-extracts`  },
    { '@type': 'Organization', name: 'Plaito',         url: `${SITE_ORIGIN}/ventures/plaito`         },
    { '@type': 'Organization', name: 'SISU Ventures',  url: `${SITE_ORIGIN}/ventures/sisu-ventures`  },
  ],
  homeLocation: { '@type': 'Place', name: 'Sierra Foothills, California, USA' },
  // sameAs: external profile URLs that disambiguate this Person entity for
  // Google's Knowledge Graph. Keep this list TIGHT — only canonical, verified
  // profiles. Duplicates (e.g. two LinkedIn URLs) hurt entity merging.
  // The Wikidata URL must come first — it's the most authoritative identifier.
  sameAs: [
    'https://www.wikidata.org/wiki/Q139560701',
    'https://www.linkedin.com/in/john-fig/',
    'https://www.instagram.com/fig.time/',
    'https://x.com/fig_time_',
    'https://github.com/johnfig',
    'https://www.crunchbase.com/person/john-figueiredo',
    'https://pitchbook.com/profiles/company/433116-28',
    'https://mgmagazine.com/business/retail-merchandise/sisu-extracts-turning-trim-into-gold/',
    'https://mjbizdaily.com/how-to-keep-extraction-costs-low/',
    'https://www.cannabisbusinesstimes.com/business-issues-benchmarks/finance/news/15691093/left-coast-ventures-announces-acquisition-of-sisu-extracts',
    'https://www.businesswire.com/news/home/20200310005364/en/Left-Coast-Ventures-Announces-Acquisition-of-Sisu-Extracts',
    'https://extractionmagazine.com/2019/07/03/leading-california-extractor-fills-two-million-cartridges-per-month-with-next-generation-distillate/',
    'https://www.greenmarketreport.com/subversive-spac-forms-the-parent-company-with-jaz-z-roc-nation/',
    'https://www.benzinga.com/markets/cannabis/22/11/29547180/the-parent-company-divests-wholesale-cannabis-extraction-division',
    'https://rwsmagazine.com/plaitos-ai-education-platform-to-reach-1m-downloads/',
    'https://podcasts.apple.com/us/podcast/sisu-extracts-john-figueiredo-joe-wynne/id1455758113?i=1000441098909',
    'https://www.youtube.com/watch?v=wdzl2ribBxE',
    'https://music.amazon.ca/podcasts/d9b85ea7-294f-421d-a5ca-ef6c0dd2faa3/episodes/f4b3de2c-b209-4596-a39d-26a9a74aceeb',
  ],
  // subjectOf: independent press coverage about this Person. Mirrors what
  // Knowledge Graph editors look for when validating an entity.
  subjectOf: [
    {
      '@type': 'NewsArticle',
      headline: 'Left Coast Ventures Announces Acquisition of Sisu Extracts',
      url: 'https://www.businesswire.com/news/home/20200310005364/en/Left-Coast-Ventures-Announces-Acquisition-of-Sisu-Extracts',
      publisher: { '@type': 'Organization', name: 'Business Wire' },
    },
    {
      '@type': 'NewsArticle',
      headline: 'SISU Extracts: Turning Trim Into Gold',
      url: 'https://mgmagazine.com/business/retail-merchandise/sisu-extracts-turning-trim-into-gold/',
      publisher: { '@type': 'Organization', name: 'MG Magazine' },
    },
    {
      '@type': 'NewsArticle',
      headline: 'Subversive SPAC Forms The Parent Company with Jay-Z & Roc Nation',
      url: 'https://www.greenmarketreport.com/subversive-spac-forms-the-parent-company-with-jaz-z-roc-nation/',
      publisher: { '@type': 'Organization', name: 'Green Market Report' },
    },
    {
      '@type': 'NewsArticle',
      headline: "Plaito's AI Education Platform To Reach 1M Downloads",
      url: 'https://rwsmagazine.com/plaitos-ai-education-platform-to-reach-1m-downloads/',
      publisher: { '@type': 'Organization', name: 'RWS Magazine' },
    },
    {
      '@type': 'PodcastEpisode',
      name: 'SISU Extracts — John Figueiredo & Joe Wynne',
      url: 'https://podcasts.apple.com/us/podcast/sisu-extracts-john-figueiredo-joe-wynne/id1455758113?i=1000441098909',
    },
    {
      '@type': 'VideoObject',
      name: 'John Figueiredo on SISU Extracts (YouTube interview)',
      url: 'https://www.youtube.com/watch?v=wdzl2ribBxE',
    },
  ],
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'John Figueiredo',
  alternateName: 'johnfigueiredo.com',
  url: `${SITE_ORIGIN}/`,
  inLanguage: 'en-US',
  publisher: { '@type': 'Person', name: 'John Figueiredo', url: `${SITE_ORIGIN}/` },
};

const allJsonLd = [personSchema, websiteSchema, ...jsonLd];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content="John Figueiredo" />
    <meta name="robots" content={robotsContent} />
    <meta name="googlebot" content={robotsContent} />
    <meta name="theme-color" content="#0a0a0c" />
    <meta name="color-scheme" content="dark" />
    <meta name="format-detection" content="telephone=no" />

    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="John Figueiredo" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={absoluteOgImage} />
    <meta property="og:image:secure_url" content={absoluteOgImage} />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content="800" />
    <meta property="og:image:height" content="800" />
    <meta property="og:image:alt" content="Portrait of John Figueiredo" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteOgImage} />
    <meta name="twitter:image:alt" content="Portrait of John Figueiredo" />
    <meta name="twitter:creator" content="@fig_time_" />
    <meta name="twitter:site" content="@fig_time_" />

    <!-- Favicon -->
    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Cdefs%3E%3CradialGradient id='g' cx='30%25' cy='30%25'%3E%3Cstop offset='0%25' stop-color='%239eff5a'/%3E%3Cstop offset='60%25' stop-color='%235ad6ff'/%3E%3Cstop offset='100%25' stop-color='%23c47bff'/%3E%3C/radialGradient%3E%3C/defs%3E%3Ccircle cx='50' cy='50' r='44' fill='url(%23g)'/%3E%3C/svg%3E" />
    <link rel="apple-touch-icon" href="/assets/portrait.jpeg" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700;800;900&family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

    <!-- Sitemap (RSS-style discovery) -->
    <link rel="sitemap" type="application/xml" href="/sitemap.xml" />

    <!-- Structured data -->
    {allJsonLd.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)}></script>
    ))}
    <style is:global>
      :root {
        --bg: #0a0a0c;
        --bg-deep: #050507;
        --surface: #13131a;
        --surface-2: #1c1c26;
        --border: #2a2a36;
        --text: #f5f5f7;
        --text-soft: #a8a8b3;
        --text-dim: #6b6b78;
        --accent: #9eff5a;
        --accent-2: #5ad6ff;
        --accent-3: #ff6b3d;
        --accent-4: #c47bff;
      }
      * { box-sizing: border-box; }
      html, body {
        margin: 0; padding: 0;
        background: var(--bg); color: var(--text);
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
        overflow-x: hidden;
      }
      a { color: inherit; }
      img { max-width: 100%; height: auto; }
      .display { font-family: 'Geist', 'Inter', system-ui, sans-serif; }
      .sans    { font-family: 'Inter', system-ui, sans-serif; }
      .mono    { font-family: 'JetBrains Mono', monospace; }

      .label {
        font-family: 'JetBrains Mono', monospace;
        font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase;
        color: var(--accent); display: inline-flex; align-items: center; gap: 8px;
      }
      .label::before {
        content: ""; width: 6px; height: 6px; border-radius: 50%;
        background: currentColor; box-shadow: 0 0 8px currentColor;
      }
      .label.cyan   { color: var(--accent-2); }
      .label.violet { color: var(--accent-4); }
      .label.ember  { color: var(--accent-3); }

      .btn {
        display: inline-flex; align-items: center; gap: 8px;
        padding: 16px 28px; border-radius: 999px;
        font-family: 'Geist', 'Inter', sans-serif; font-size: 14px; font-weight: 600;
        text-decoration: none; cursor: pointer; border: none;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
      }
      .btn:hover { transform: translateY(-1px); }
      .btn-primary { background: var(--accent); color: var(--bg); box-shadow: 0 8px 30px rgba(158,255,90,0.25); }
      .btn-primary:hover { box-shadow: 0 12px 40px rgba(158,255,90,0.4); }
      .btn-ghost { background: transparent; color: var(--text); border: 1px solid var(--border); }
      .btn-ghost:hover { border-color: var(--text-soft); }
      .btn-light { background: var(--text); color: var(--bg); }

      @keyframes float1 { 0%,100% { transform: translate(0,0) } 50% { transform: translate(40px,30px) } }
      @keyframes float2 { 0%,100% { transform: translate(0,0) } 50% { transform: translate(-30px,40px) } }
      @keyframes float3 { 0%,100% { transform: translate(0,0) } 50% { transform: translate(20px,-40px) } }
      @keyframes spin   { from { transform: rotate(0) } to { transform: rotate(360deg) } }
      @keyframes fadein { from { opacity: 0; transform: translateY(4px) } to { opacity: 1; transform: translateY(0) } }

      /* Fluid hero typography */
      h1.hero-title    { font-size: clamp(40px, 9vw, 128px); }
      h1.hero-title-md { font-size: clamp(48px, 10vw, 132px); }
      h2.section-title { font-size: clamp(44px, 8vw, 88px); }
      h2.story-title   { font-size: clamp(32px, 5vw, 48px); }
      h3.card-title    { font-size: clamp(26px, 3vw, 38px); }

      /* Section padding fluid */
      .section { padding-left: clamp(20px, 4vw, 48px); padding-right: clamp(20px, 4vw, 48px); }

      /* Fold: hero + stats fill viewport on desktop; scroll cue pinned to the bottom edge */
      @media (min-width: 901px) {
        .hero-fold {
          min-height: calc(100vh - 84px);
          display: flex;
          flex-direction: column;
        }
        .hero-fold .hero-grid { flex: 1; }
        .hero-fold .hero-stats { margin-top: auto; }
      }

      /* Scroll cue beneath the stats bar — minimal chevron */
      .scroll-cue {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 24px 0 28px;
        color: var(--text-dim);
        text-decoration: none;
        transition: color 0.2s ease;
      }
      .scroll-cue:hover { color: var(--text); }
      .scroll-cue-chevron {
        animation: scrollNudge 2.2s ease-in-out infinite;
      }
      @keyframes scrollNudge {
        0%, 100% { transform: translateY(0);   opacity: 0.45; }
        50%      { transform: translateY(4px); opacity: 1; }
      }
      @media (prefers-reduced-motion: reduce) {
        .scroll-cue-chevron { animation: none; opacity: 0.7; }
      }
      html { scroll-behavior: smooth; }

      /* Tablet */
      @media (max-width: 900px) {
        .two-col { grid-template-columns: 1fr !important; gap: 36px !important; }
        .four-col { grid-template-columns: repeat(2, 1fr) !important; }
        .three-col { grid-template-columns: 1fr !important; }
        .two-col-stats { grid-template-columns: 1fr 1fr !important; }
        .stats-bar { grid-template-columns: repeat(2, 1fr) !important; gap: 20px !important; }
        .hero-grid { grid-template-columns: 1fr !important; gap: 28px !important; padding-top: 32px !important; padding-bottom: 24px !important; }
        .hero-grid .portrait-wrap { max-width: 280px !important; }
        .timeline-grid > div { padding: 8px 0 36px 24px !important; text-align: left !important; }
        .timeline-grid::before, .timeline-line { display: none !important; }
        .feed-header { flex-direction: column !important; align-items: flex-start !important; gap: 24px !important; }
        .filter-pills { overflow-x: auto !important; max-width: 100%; }
        .channel-row { grid-template-columns: 90px 1fr !important; }
        .channel-row .channel-status { display: none !important; }
        .stats-card { padding: 20px !important; }
        .stats-card > div { padding-left: 0 !important; border-left: none !important; }
      }

      /* Phone */
      @media (max-width: 640px) {
        .nav-desktop { display: none !important; }
        .nav-mobile-toggle { display: inline-flex !important; }
        .hero-grid .portrait-wrap { max-width: 220px !important; }
        h1.hero-title { font-size: clamp(36px, 12vw, 64px) !important; }
      }

      /* Mobile drawer */
      .nav-mobile-drawer {
        display: none;
        position: fixed;
        top: 0; left: 0; right: 0;
        background: rgba(10,10,12,0.97);
        backdrop-filter: blur(24px);
        -webkit-backdrop-filter: blur(24px);
        z-index: 100;
        padding: 80px 24px 32px;
        flex-direction: column;
        gap: 4px;
        border-bottom: 1px solid var(--border);
      }
      .nav-mobile-drawer.open { display: flex; }
      .nav-mobile-drawer a {
        padding: 18px 20px;
        border-radius: 12px;
        text-decoration: none;
        color: var(--text);
        font-family: 'Geist', 'Inter', sans-serif;
        font-size: 22px;
        font-weight: 600;
        letter-spacing: -0.01em;
        border: 1px solid transparent;
      }
      .nav-mobile-drawer a:hover,
      .nav-mobile-drawer a.active {
        background: var(--surface);
        border-color: var(--border);
      }
      .nav-mobile-toggle {
        display: none;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 10px 12px;
        cursor: pointer;
        align-items: center;
        justify-content: center;
        z-index: 110;
        position: relative;
      }
      .nav-mobile-toggle span {
        display: block;
        width: 22px; height: 2px;
        background: var(--text);
        position: relative;
      }
      .nav-mobile-toggle span::before,
      .nav-mobile-toggle span::after {
        content: ""; position: absolute; left: 0;
        width: 22px; height: 2px; background: var(--text);
        transition: transform 0.2s ease;
      }
      .nav-mobile-toggle span::before { top: -7px; }
      .nav-mobile-toggle span::after  { top: 7px; }
      .nav-mobile-toggle.open span { background: transparent; }
      .nav-mobile-toggle.open span::before { transform: translateY(7px) rotate(45deg); }
      .nav-mobile-toggle.open span::after  { transform: translateY(-7px) rotate(-45deg); }
    </style>
  </head>
  <body>
    <Nav active={active} />
    <slot />
    <Footer />

    <script is:inline>
      (function () {
        const toggle = document.querySelector('.nav-mobile-toggle');
        const drawer = document.querySelector('.nav-mobile-drawer');
        if (!toggle || !drawer) return;
        toggle.addEventListener('click', () => {
          toggle.classList.toggle('open');
          drawer.classList.toggle('open');
          document.body.style.overflow = drawer.classList.contains('open') ? 'hidden' : '';
        });
        drawer.querySelectorAll('a').forEach((a) => {
          a.addEventListener('click', () => {
            toggle.classList.remove('open');
            drawer.classList.remove('open');
            document.body.style.overflow = '';
          });
        });
      })();
    </script>
  </body>
</html>
